# 依赖目录（npm/yarn/pnpm）
node_modules/
# pnpm 存储目录
.pnpm-store/

# 构建产物
dist/
# 如果使用 Vite 开发服务器的预构建缓存
node_modules/.vite/

# 环境变量文件（包含敏感信息）
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 日志文件
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 编辑器/IDE 配置
.idea/
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 缓存文件
*.cache
.eslintcache

# 如果使用 TypeScript
*.tsbuildinfo
# TypeScript 编译产物（如果未通过 Vite 构建）
*.js.map
*.d.ts.map

# 如果使用 Vue/React 等框架的临时文件
*.local

# 包管理器锁文件（可选：如果团队统一锁版本，可取消注释保留）
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
